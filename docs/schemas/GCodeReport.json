{
  "$defs": {
    "ArtifactError": {
      "additionalProperties": false,
      "description": "A single structured failure, so an agent can branch without parsing prose.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "context": {
          "additionalProperties": true,
          "title": "Context",
          "type": "object"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "stage": {
          "title": "Stage",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "stage"
      ],
      "title": "ArtifactError",
      "type": "object"
    },
    "Status": {
      "description": "Outcome of a stage, or of a single evaluation check.",
      "enum": [
        "ok",
        "warning",
        "error"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "errors": {
      "items": {
        "$ref": "#/$defs/ArtifactError"
      },
      "title": "Errors",
      "type": "array"
    },
    "estimated_time_s": {
      "title": "Estimated Time S",
      "type": "number"
    },
    "filament_length_mm": {
      "title": "Filament Length Mm",
      "type": "number"
    },
    "filament_mass_g": {
      "title": "Filament Mass G",
      "type": "number"
    },
    "filament_volume_mm3": {
      "title": "Filament Volume Mm3",
      "type": "number"
    },
    "first_layer_height_mm": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "First Layer Height Mm"
    },
    "gcode_sha256": {
      "title": "Gcode Sha256",
      "type": "string"
    },
    "layer_count": {
      "title": "Layer Count",
      "type": "integer"
    },
    "layer_height_mm": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Layer Height Mm"
    },
    "material_density_g_cm3": {
      "title": "Material Density G Cm3",
      "type": "number"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_backend": {
      "title": "Source Backend",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status",
      "default": "ok"
    }
  },
  "required": [
    "source_backend",
    "gcode_sha256",
    "layer_count",
    "filament_length_mm",
    "filament_volume_mm3",
    "filament_mass_g",
    "material_density_g_cm3",
    "estimated_time_s"
  ],
  "title": "GCodeReport",
  "type": "object"
}
