{
  "$defs": {
    "ArtifactError": {
      "additionalProperties": false,
      "description": "A single structured failure, so an agent can branch without parsing prose.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "context": {
          "additionalProperties": true,
          "title": "Context",
          "type": "object"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "stage": {
          "title": "Stage",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "stage"
      ],
      "title": "ArtifactError",
      "type": "object"
    },
    "ProbedPoint": {
      "additionalProperties": false,
      "properties": {
        "classification": {
          "enum": [
            "IN",
            "OUT",
            "ON"
          ],
          "title": "Classification",
          "type": "string"
        },
        "point_mm": {
          "maxItems": 3,
          "minItems": 3,
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "title": "Point Mm",
          "type": "array"
        }
      },
      "required": [
        "point_mm",
        "classification"
      ],
      "title": "ProbedPoint",
      "type": "object"
    },
    "Status": {
      "description": "Outcome of a stage, or of a single evaluation check.",
      "enum": [
        "ok",
        "warning",
        "error"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "printlab.cad.probe.classify_points() -> probe_report.json.\n\nClassifies each requested point against the built solid (from `part.step`,\nthe exact CAD boundary representation -- not the tessellated STL) using\nOCP's `BRepClass3d_SolidClassifier`, within `tolerance_mm` of the surface\ncounting as \"ON\" rather than \"IN\"/\"OUT\".",
  "properties": {
    "errors": {
      "items": {
        "$ref": "#/$defs/ArtifactError"
      },
      "title": "Errors",
      "type": "array"
    },
    "input_path": {
      "format": "path",
      "title": "Input Path",
      "type": "string"
    },
    "input_sha256": {
      "title": "Input Sha256",
      "type": "string"
    },
    "points": {
      "items": {
        "$ref": "#/$defs/ProbedPoint"
      },
      "title": "Points",
      "type": "array"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status",
      "default": "ok"
    },
    "tolerance_mm": {
      "title": "Tolerance Mm",
      "type": "number"
    }
  },
  "required": [
    "input_path",
    "input_sha256",
    "tolerance_mm",
    "points"
  ],
  "title": "ProbeReport",
  "type": "object"
}
