{
  "$defs": {
    "ArtifactError": {
      "additionalProperties": false,
      "description": "A single structured failure, so an agent can branch without parsing prose.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "context": {
          "additionalProperties": true,
          "title": "Context",
          "type": "object"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "stage": {
          "title": "Stage",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "stage"
      ],
      "title": "ArtifactError",
      "type": "object"
    },
    "RenderedView": {
      "additionalProperties": false,
      "description": "One rendered PNG and the camera that produced it.\n\nEchoes the CameraView angles back (see printlab.rendering.mpl) so the JSON\nfully documents how the image was framed without needing to reconstruct the\nview from the filename.",
      "properties": {
        "azimuth_deg": {
          "title": "Azimuth Deg",
          "type": "number"
        },
        "elevation_deg": {
          "title": "Elevation Deg",
          "type": "number"
        },
        "height_px": {
          "title": "Height Px",
          "type": "integer"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "output_path": {
          "format": "path",
          "title": "Output Path",
          "type": "string"
        },
        "roll_deg": {
          "default": 0.0,
          "title": "Roll Deg",
          "type": "number"
        },
        "width_px": {
          "title": "Width Px",
          "type": "integer"
        }
      },
      "required": [
        "label",
        "elevation_deg",
        "azimuth_deg",
        "output_path",
        "width_px",
        "height_px"
      ],
      "title": "RenderedView",
      "type": "object"
    },
    "Status": {
      "description": "Outcome of a stage, or of a single evaluation check.",
      "enum": [
        "ok",
        "warning",
        "error"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "printlab.rendering.render_views() -> render_report.json.\n\n`input_sha256`/`input_path` fingerprint the source STL; they are supplied\nby the caller (the pipeline integration), since render_views() operates on\nan in-memory trimesh.Trimesh rather than a file path -- see\nprintlab.rendering.mpl.",
  "properties": {
    "errors": {
      "items": {
        "$ref": "#/$defs/ArtifactError"
      },
      "title": "Errors",
      "type": "array"
    },
    "input_path": {
      "format": "path",
      "title": "Input Path",
      "type": "string"
    },
    "input_sha256": {
      "title": "Input Sha256",
      "type": "string"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status",
      "default": "ok"
    },
    "views": {
      "items": {
        "$ref": "#/$defs/RenderedView"
      },
      "title": "Views",
      "type": "array"
    }
  },
  "required": [
    "input_path",
    "input_sha256"
  ],
  "title": "RenderReport",
  "type": "object"
}
