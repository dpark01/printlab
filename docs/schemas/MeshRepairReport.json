{
  "$defs": {
    "ArtifactError": {
      "additionalProperties": false,
      "description": "A single structured failure, so an agent can branch without parsing prose.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "context": {
          "additionalProperties": true,
          "title": "Context",
          "type": "object"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "stage": {
          "title": "Stage",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "stage"
      ],
      "title": "ArtifactError",
      "type": "object"
    },
    "Status": {
      "description": "Outcome of a stage, or of a single evaluation check.",
      "enum": [
        "ok",
        "warning",
        "error"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "printlab.mesh.repair() -> mesh_repair_report.json.\n\nOnly the cheap, well-understood fixes trimesh ships are attempted\n(degenerate-face removal, vertex merging, hole filling, normal/winding\ncorrection) -- this is not a general-purpose mesh-healing tool. If a\nmesh is still broken afterward, that's reported plainly rather than\nhidden; PrintLab does not claim to fix everything.",
  "properties": {
    "errors": {
      "items": {
        "$ref": "#/$defs/ArtifactError"
      },
      "title": "Errors",
      "type": "array"
    },
    "fixes_applied": {
      "items": {
        "type": "string"
      },
      "title": "Fixes Applied",
      "type": "array"
    },
    "input_path": {
      "format": "path",
      "title": "Input Path",
      "type": "string"
    },
    "input_sha256": {
      "title": "Input Sha256",
      "type": "string"
    },
    "manifold_after": {
      "title": "Manifold After",
      "type": "boolean"
    },
    "manifold_before": {
      "title": "Manifold Before",
      "type": "boolean"
    },
    "output_path": {
      "anyOf": [
        {
          "format": "path",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Output Path"
    },
    "repair_attempted": {
      "title": "Repair Attempted",
      "type": "boolean"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status",
      "default": "ok"
    },
    "watertight_after": {
      "title": "Watertight After",
      "type": "boolean"
    },
    "watertight_before": {
      "title": "Watertight Before",
      "type": "boolean"
    }
  },
  "required": [
    "input_path",
    "input_sha256",
    "repair_attempted",
    "manifold_before",
    "watertight_before",
    "manifold_after",
    "watertight_after"
  ],
  "title": "MeshRepairReport",
  "type": "object"
}
