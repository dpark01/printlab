{
  "$defs": {
    "ArtifactError": {
      "additionalProperties": false,
      "description": "A single structured failure, so an agent can branch without parsing prose.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "context": {
          "additionalProperties": true,
          "title": "Context",
          "type": "object"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "stage": {
          "title": "Stage",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "stage"
      ],
      "title": "ArtifactError",
      "type": "object"
    },
    "Status": {
      "description": "Outcome of a stage, or of a single evaluation check.",
      "enum": [
        "ok",
        "warning",
        "error"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "backend_name": {
      "title": "Backend Name",
      "type": "string"
    },
    "dependencies": {
      "items": {
        "type": "string"
      },
      "title": "Dependencies",
      "type": "array"
    },
    "errors": {
      "items": {
        "$ref": "#/$defs/ArtifactError"
      },
      "title": "Errors",
      "type": "array"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "settings": {
      "additionalProperties": true,
      "title": "Settings",
      "type": "object"
    },
    "source_path": {
      "title": "Source Path",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status",
      "default": "ok"
    },
    "step_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Step Path"
    },
    "stl_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Stl Path"
    },
    "tool_versions": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Tool Versions",
      "type": "object"
    }
  },
  "required": [
    "backend_name",
    "source_path"
  ],
  "title": "CadBuildReport",
  "type": "object"
}
