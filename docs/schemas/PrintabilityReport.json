{
  "$defs": {
    "ArtifactError": {
      "additionalProperties": false,
      "description": "A single structured failure, so an agent can branch without parsing prose.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "context": {
          "additionalProperties": true,
          "title": "Context",
          "type": "object"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "stage": {
          "title": "Stage",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "stage"
      ],
      "title": "ArtifactError",
      "type": "object"
    },
    "PrintabilityCheck": {
      "additionalProperties": false,
      "properties": {
        "message": {
          "title": "Message",
          "type": "string"
        },
        "metric_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "boolean"
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metric Value"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/Status"
        },
        "threshold": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Threshold"
        }
      },
      "required": [
        "name",
        "status",
        "message"
      ],
      "title": "PrintabilityCheck",
      "type": "object"
    },
    "Status": {
      "description": "Outcome of a stage, or of a single evaluation check.",
      "enum": [
        "ok",
        "warning",
        "error"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "checks": {
      "items": {
        "$ref": "#/$defs/PrintabilityCheck"
      },
      "title": "Checks",
      "type": "array"
    },
    "errors": {
      "items": {
        "$ref": "#/$defs/ArtifactError"
      },
      "title": "Errors",
      "type": "array"
    },
    "metrics": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "integer"
          },
          {
            "type": "boolean"
          },
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      },
      "title": "Metrics",
      "type": "object"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/Status",
      "default": "ok"
    }
  },
  "title": "PrintabilityReport",
  "type": "object"
}
